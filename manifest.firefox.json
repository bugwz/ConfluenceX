{
  "manifest_version": 2,
  "name": "ConfluenceX",
  "version": "0.0.0",
  "default_locale": "en",
  "description": "AI-powered sidebar for Confluence: edit pages, move pages, dark mode and more.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "*://*/*"
  ],
  "background": {
    "page": "background/background.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": [
        "shared/browser-polyfill.js",
        "shared/constants.js",
        "shared/message-types.js",
        "content/page-detector.js",
        "content/scroll-to-top.js",
        "content/dark-mode.js",
        "content/content-main.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "sidebar_action": {
    "default_panel": "sidepanel/sidepanel.html",
    "default_title": "ConfluenceX",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    "content/dark-mode.css"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "confluencex@confluencex.io",
      "strict_min_version": "109.0"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'"
}
