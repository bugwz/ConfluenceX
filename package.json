{
  "name": "confluencex",
  "version": "0.0.0",
  "description": "AI-powered browser extension for Confluence Server 7.x — AI chat editing, page move, dark mode, and more.",
  "homepage": "https://github.com/confluencex/confluencex",
  "license": "MIT",
  "private": true,
  "keywords": [
    "confluence",
    "browser-extension",
